+                // ShieldSpigot - skip PlayerMoveEvent when there are no listeners
+                if (this.hasPlayerMoveEvent) {
                 Player player = this.getPlayer();
                 // Spigot Start
                 if ( !hasMoved )
@@ -734,6 +740,7 @@ public class PlayerConnection implements PacketListenerPlayIn {
                         }
                     }
                 }
+                }
                 // CraftBukkit end
 
                 this.player.getWorldServer().getChunkProvider().movePlayer(this.player);
@@ -1487,6 +1494,8 @@ public class PlayerConnection implements PacketListenerPlayIn {
                                 this.a(d0, d1, d2, f, f1);
                             } else {
                                 // CraftBukkit start - fire PlayerMoveEvent
+                                // ShieldSpigot - skip PlayerMoveEvent when there are no listeners
+                                if (this.hasPlayerMoveEvent) {
                                 // Rest to old location first
                                 this.player.setLocation(prevX, prevY, prevZ, prevYaw, prevPitch);
 
